generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  DM
  PLAYER
}

enum CharacterType {
  PG
  PNG
}

enum MonsterSourceType {
  SRD
  CUSTOM
}

enum SpellSourceType {
  SRD
  CUSTOM
}

enum RuleSourceType {
  SRD
  CUSTOM
}

enum ChatSenderRole {
  DM
  PLAYER
  SYSTEM
}

enum EncounterScenarioEntryType {
  BESTIARY
  MANUAL
}

enum ItemCategory {
  WEAPON
  ARMOR
  SHIELD
  WONDROUS_ITEM
  RING
  AMULET
  ROD
  STAFF
  WAND
  TOOL
  CONSUMABLE
  AMMUNITION
  GEAR
  QUEST
  OTHER
}

enum WeaponHandling {
  ONE_HANDED
  TWO_HANDED
  VERSATILE
}

enum GloveWearMode {
  SINGLE
  PAIR
}

enum ArmorCategory {
  LIGHT
  MEDIUM
  HEAVY
  SHIELD
}

enum ArmorClassCalculation {
  BASE_PLUS_DEX
  BASE_PLUS_DEX_MAX_2
  BASE_ONLY
  BONUS_ONLY
}

enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  VERY_RARE
  LEGENDARY
  ARTIFACT
  UNIQUE
}

enum EquipmentSlot {
  HEAD
  BACK
  ARMOR
  GLOVE_LEFT
  GLOVE_RIGHT
  RING_1
  RING_2
  RING_3
  RING_4
  RING_5
  RING_6
  RING_7
  RING_8
  RING_9
  RING_10
  NECK
  FEET
  WEAPON_HAND_LEFT
  WEAPON_HAND_RIGHT
}

enum SlotSelectionMode {
  ALL_REQUIRED
  ANY_ONE
}

enum AttackKind {
  MELEE_WEAPON
  RANGED_WEAPON
  THROWN
  SPECIAL
}

enum AttackHandRequirement {
  ANY
  ONE_HANDED
  TWO_HANDED
}

enum ModifierTarget {
  ARMOR_CLASS
  STRENGTH
  DEXTERITY
  CONSTITUTION
  INTELLIGENCE
  WISDOM
  CHARISMA
  SPEED
  INITIATIVE
  HIT_POINT_MAX
}

enum ModifierType {
  FLAT
  FORMULA
  SET_MIN
  OVERRIDE
}

enum EffectCondition {
  ALWAYS
  WHILE_EQUIPPED
}

enum AbilityScore {
  STRENGTH
  DEXTERITY
  CONSTITUTION
  INTELLIGENCE
  WISDOM
  CHARISMA
}

enum ItemUseEffectType {
  HEAL
  DAMAGE
  TEMP_HP
  APPLY_CONDITION
  REMOVE_CONDITION
  RESTORE_RESOURCE
  CUSTOM
}

enum ItemUseTargetType {
  SELF
  CREATURE
  OBJECT
  AREA
  CUSTOM
}

enum ItemUseSuccessOutcome {
  NONE
  HALF
  NEGATES
  CUSTOM
}

enum ItemFeatureReset {
  AT_WILL
  ENCOUNTER
  SHORT_REST
  LONG_REST
  DAILY
  CUSTOM
}

enum InventoryOwnerType {
  CHARACTER
  NPC
  SYSTEM
}

enum InventoryTransactionType {
  INITIAL_GRANT
  LOOT
  TRANSFER
  PURCHASE
  SALE
  GIFT
  CONSUME
  DESTROY
  DROP
  OTHER
}

enum CurrencyType {
  CP
  SP
  EP
  GP
  PP
}

enum MonsterPowerTag {
  DEBOLISSIMO
  DEBOLE
  FORTE
  FORTISSIMO
}

enum MonsterKnowledgeState {
  UNKNOWN
  BASIC
  COMPLETE
}

model User {
  id                 String   @id
  username           String   @unique
  displayName        String
  role               UserRole
  passwordSalt       String
  passwordHash       String
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  ownedCharacters   Character[]         @relation("CharacterOwner")
  createdCharacters Character[]         @relation("CharacterCreator")
  sentMessages      ChatMessage[]       @relation("UserSentMessages")
  scenarios         EncounterScenario[] @relation("ScenarioCreator")
  sessions          Session[]
  inventoryTransactionsCreated InventoryTransaction[] @relation("InventoryTransactionCreatedBy")

  @@index([role])
}

model Character {
  id              String        @id
  slug            String        @unique
  name            String
  characterType   CharacterType
  ownerUserId     String?
  createdByUserId String?
  className       String?
  race            String?
  alignment       String?
  background      String?
  level           Int?
  portraitUrl     String?
  archivedAt      DateTime?
  data            String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  owner     User?         @relation("CharacterOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdBy User?         @relation("CharacterCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  messages  ChatMessage[]
  inventoryItems CharacterItem[]
  inventoryTransactionsFrom InventoryTransaction[] @relation("InventoryTransactionFromCharacter")
  inventoryTransactionsTo   InventoryTransaction[] @relation("InventoryTransactionToCharacter")

  @@index([characterType])
  @@index([ownerUserId])
  @@index([createdByUserId])
  @@index([archivedAt])
}

model Monster {
  id                     String            @id
  slug                   String            @unique
  name                   String
  sourceType             MonsterSourceType
  sourceFile             String?
  challengeRatingDisplay String?
  challengeRatingDecimal Float?
  challengeRatingXp      Int?
  size                   String?
  creatureType           String?
  rarity                 String?
  alignment              String?
  archivedAt             DateTime?
  data                   String
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  scenarioEntries        EncounterScenarioEntry[]
  compendiumEntry        MonsterCompendiumEntry?

  @@index([sourceType])
  @@index([name])
  @@index([challengeRatingDecimal])
  @@index([rarity])
  @@index([archivedAt])
}

model MonsterCompendiumEntry {
  monsterId       String                @id
  knowledgeState  MonsterKnowledgeState @default(UNKNOWN)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  monster Monster @relation(fields: [monsterId], references: [id], onDelete: Cascade)

  @@index([knowledgeState])
}

model Spell {
  id            String          @id
  slug          String          @unique
  name          String
  level         Int
  school        String?
  castingTime   String?
  range         String?
  duration      String?
  concentration Boolean         @default(false)
  ritual        Boolean         @default(false)
  sourceType    SpellSourceType
  sourceUrl     String?
  classes       String
  data          String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([name])
  @@index([level])
  @@index([school])
  @@index([sourceType])
}

model Skill {
  id         String         @id
  slug       String         @unique
  name       String
  ability    String
  sourceType RuleSourceType
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  monsterDiscoverSkillRules MonsterDiscoverSkillRule[]

  @@index([name])
  @@index([ability])
  @@index([sourceType])
}

model ItemDefinition {
  id            String       @id
  slug          String       @unique
  name          String
  category      ItemCategory
  subcategory   String?
  weaponHandling WeaponHandling?
  gloveWearMode  GloveWearMode?
  armorCategory  ArmorCategory?
  armorClassCalculation ArmorClassCalculation?
  armorClassBase Int?
  armorClassBonus Int?
  rarity        ItemRarity?
  description   String?
  stackable     Boolean      @default(false)
  equippable    Boolean      @default(false)
  attunement    Boolean      @default(false)
  weight        Float?
  valueCp       Int?
  data          String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  slotRules      ItemSlotRule[]
  attacks        ItemAttack[]
  modifiers      ItemModifier[]
  features       ItemFeature[]
  abilityRequirements ItemAbilityRequirement[]
  useEffects     ItemUseEffect[]
  characterItems CharacterItem[]
  transactionItems InventoryTransactionItem[]

  @@index([category])
  @@index([name])
  @@index([rarity])
}

model CharacterItem {
  id                  String    @id
  characterId         String
  itemDefinitionId    String?
  nameOverride        String?
  descriptionOverride String?
  quantity            Int       @default(1)
  isEquipped          Boolean   @default(false)
  sortOrder           Int       @default(0)
  notes               String?
  data                String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  character      Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemDefinition ItemDefinition? @relation(fields: [itemDefinitionId], references: [id], onDelete: SetNull)
  equippedSlots  CharacterItemEquip[]
  transactionItems InventoryTransactionItem[]
  featureStates CharacterItemFeatureState[]

  @@index([characterId, sortOrder])
  @@index([itemDefinitionId])
  @@index([isEquipped])
}

model ItemSlotRule {
  id               String        @id
  itemDefinitionId String
  groupKey         String        @default("default")
  selectionMode    SlotSelectionMode @default(ALL_REQUIRED)
  slot             EquipmentSlot
  required         Boolean       @default(true)
  sortOrder        Int           @default(0)

  itemDefinition ItemDefinition @relation(fields: [itemDefinitionId], references: [id], onDelete: Cascade)

  @@index([itemDefinitionId])
  @@index([itemDefinitionId, groupKey, sortOrder])
  @@index([slot])
}

model CharacterItemEquip {
  id              String        @id
  characterItemId String
  slot            EquipmentSlot

  characterItem CharacterItem @relation(fields: [characterItemId], references: [id], onDelete: Cascade)

  @@unique([characterItemId, slot])
  @@index([slot])
}

model ItemAttack {
  id               String     @id
  itemDefinitionId String
  name             String
  kind             AttackKind
  handRequirement  AttackHandRequirement @default(ANY)
  ability          String?
  attackBonus      Int?
  damageDice       String?
  damageType       String?
  rangeNormal      Int?
  rangeLong        Int?
  twoHandedOnly    Boolean    @default(false)
  requiresEquipped Boolean    @default(true)
  conditionText    String?
  sortOrder        Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  itemDefinition ItemDefinition @relation(fields: [itemDefinitionId], references: [id], onDelete: Cascade)

  @@index([itemDefinitionId, sortOrder])
  @@index([kind])
}

model ItemModifier {
  id               String          @id
  itemDefinitionId String
  target           ModifierTarget
  type             ModifierType
  value            Int?
  formula          String?
  condition        EffectCondition @default(WHILE_EQUIPPED)
  stackKey         String?
  sortOrder        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  itemDefinition ItemDefinition @relation(fields: [itemDefinitionId], references: [id], onDelete: Cascade)

  @@index([itemDefinitionId, sortOrder])
  @@index([target, condition])
}

model ItemFeature {
  id               String          @id
  itemDefinitionId String
  name             String
  description      String?
  resetOn          ItemFeatureReset?
  customResetLabel String?
  maxUses          Int?
  condition        EffectCondition @default(WHILE_EQUIPPED)
  sortOrder        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  itemDefinition ItemDefinition @relation(fields: [itemDefinitionId], references: [id], onDelete: Cascade)
  featureStates   CharacterItemFeatureState[]

  @@index([itemDefinitionId, sortOrder])
}

model ItemAbilityRequirement {
  id               String       @id
  itemDefinitionId String
  ability          AbilityScore
  minScore         Int
  sortOrder        Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  itemDefinition ItemDefinition @relation(fields: [itemDefinitionId], references: [id], onDelete: Cascade)

  @@index([itemDefinitionId, sortOrder])
  @@index([ability])
}

model ItemUseEffect {
  id                String               @id
  itemDefinitionId  String
  effectType        ItemUseEffectType
  targetType        ItemUseTargetType
  diceExpression    String?
  flatValue         Int?
  damageType        String?
  savingThrowAbility AbilityScore?
  savingThrowDc     Int?
  successOutcome    ItemUseSuccessOutcome?
  durationText      String?
  notes             String?
  sortOrder         Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  itemDefinition ItemDefinition @relation(fields: [itemDefinitionId], references: [id], onDelete: Cascade)

  @@index([itemDefinitionId, sortOrder])
  @@index([effectType])
}

model CharacterItemFeatureState {
  id              String   @id
  characterItemId String
  itemFeatureId   String
  usesSpent       Int      @default(0)
  lastResetAt     DateTime?
  updatedAt       DateTime @updatedAt

  characterItem CharacterItem @relation(fields: [characterItemId], references: [id], onDelete: Cascade)
  itemFeature   ItemFeature   @relation(fields: [itemFeatureId], references: [id], onDelete: Cascade)

  @@unique([characterItemId, itemFeatureId])
  @@index([characterItemId])
  @@index([itemFeatureId])
}

model InventoryTransaction {
  id               String                   @id
  type             InventoryTransactionType
  fromOwnerType    InventoryOwnerType?
  fromCharacterId  String?
  fromNpcName      String?
  toOwnerType      InventoryOwnerType?
  toCharacterId    String?
  toNpcName        String?
  notes            String?
  createdByUserId  String?
  createdAt        DateTime                 @default(now())

  fromCharacter Character?                 @relation("InventoryTransactionFromCharacter", fields: [fromCharacterId], references: [id], onDelete: SetNull)
  toCharacter   Character?                 @relation("InventoryTransactionToCharacter", fields: [toCharacterId], references: [id], onDelete: SetNull)
  createdBy     User?                      @relation("InventoryTransactionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items         InventoryTransactionItem[]
  currencies    InventoryTransactionCurrency[]

  @@index([type, createdAt])
  @@index([fromCharacterId])
  @@index([toCharacterId])
  @@index([createdByUserId])
}

model InventoryTransactionItem {
  id                 String                @id
  transactionId      String
  characterItemId    String?
  itemDefinitionId   String?
  descriptionSnapshot String?
  quantity           Int                   @default(1)

  transaction    InventoryTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  characterItem   CharacterItem?        @relation(fields: [characterItemId], references: [id], onDelete: SetNull)
  itemDefinition  ItemDefinition?       @relation(fields: [itemDefinitionId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([characterItemId])
  @@index([itemDefinitionId])
}

model InventoryTransactionCurrency {
  id            String                @id
  transactionId String
  currencyType  CurrencyType
  amount        Int

  transaction InventoryTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([currencyType])
}

model MonsterDiscoverSkillRule {
  id           String   @id
  creatureType String
  subtype      String   @default("")
  skillId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@unique([creatureType, subtype])
  @@index([skillId])
}

model MonsterDiscoveryDcByCrRule {
  id        String   @id
  minCr     Float
  maxCr     Float?
  dc        Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([minCr, maxCr])
}

model MonsterDiscoveryDcByRarityRule {
  id        String   @id
  rarity    String   @unique
  dc        Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SpellSlotProgression {
  id             String         @id
  classSlug      String
  className      String
  characterLevel Int
  slots          String
  sourceType     RuleSourceType
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([classSlug, characterLevel])
  @@index([classSlug, characterLevel])
  @@index([sourceType])
}

model Session {
  id         String   @id
  userId     String
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ChatMessage {
  id           String         @id
  characterId  String
  senderUserId String?
  senderRole   ChatSenderRole
  text         String
  createdAt    DateTime       @default(now())

  character  Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  senderUser User?     @relation("UserSentMessages", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([characterId, createdAt])
  @@index([senderUserId])
}

model EncounterScenario {
  id              String   @id
  name            String
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User?                     @relation("ScenarioCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  entries    EncounterScenarioEntry[]

  @@index([name])
  @@index([createdByUserId])
}

model EncounterScenarioEntry {
  id         String                     @id
  scenarioId String
  entryType  EncounterScenarioEntryType
  sortOrder  Int
  monsterId  String?
  name       String
  count      Int
  armorClass Int?
  hitPoints  Int?
  powerTag   MonsterPowerTag?
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt

  scenario EncounterScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  monster  Monster?          @relation(fields: [monsterId], references: [id], onDelete: SetNull)

  @@index([scenarioId, sortOrder])
  @@index([monsterId])
  @@index([entryType])
}
